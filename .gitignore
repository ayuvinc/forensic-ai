# Environment
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
.venv/
env/
ENV/

# Runtime-generated case data (never commit client data)
cases/
firm_profile/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Claude Code local settings
.claude/settings.local.json

# Temporary files
*.tmp
*.bak

# AK-Cognitive-OS hook flag files (runtime state, not committed)
.teach-me-required
.codex-prep-required
.session-state-transition

# Activity log events (runtime-generated, not committed; .gitkeep tracked)
logs/*.jsonl
# Crash reports (runtime-generated, not committed; directory tracked via .gitkeep)
logs/crash_reports/*.json
# MCP server runtime logs (runtime-generated, not committed)
logs/mcp/*.log

# Session lock files (session-open/session-close fallback path)
tasks/.session-transition-lock
