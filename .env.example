# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
TAVILY_API_KEY=tvly-your-key-here

# ── Budget Mode ───────────────────────────────────────────────────────────────
# Options: economy | balanced | premium  (default: balanced)
BUDGET_MODE=balanced

# ── Research ──────────────────────────────────────────────────────────────────
# Set to true to reuse cached Tavily results and save quota
USE_CACHED_RESEARCH=false

# ── Cases Directory ───────────────────────────────────────────────────────────
# Where case folders are saved (default: cases/ inside this repo)
CASES_DIR=cases
