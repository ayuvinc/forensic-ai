{
  "plugin_id": "junior_analyst",
  "role": "junior",
  "plugin_type": "agent",
  "version": "1.0.0",
  "enabled": true,
  "supported_workflows": [
    "investigation_report",
    "frm_risk_register",
    "policy_sop",
    "training_material",
    "client_proposal",
    "proposal_deck"
  ],
